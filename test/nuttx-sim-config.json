{
    "system": {
        "privileged": true
    },
    "supervisor": {
        "imagePath": "/data/wanted/supervisor.tar",
        "params": {
            "console": {
                "in":  {"name": "platform"},
                "out": {"name": "platform"},
                "err": {"name": "platform"}
            },
            "drivers": [
                {"name": "wanted"}
            ],
            "mounts": [
                {"name": "config", "path": "/etc/config", "options": "selftest-cfgmap-v1"},
                {"name": "log", "path": "/log"}
            ],
            "sockets": [
                {"name": "uplink", "address": "tcp://localhost:8899"},
                {"name": "tlslink", "address": "tcps://localhost:8889"}
            ]
        }
    }
}
