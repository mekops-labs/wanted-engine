.vscode
build
build-*
compile_commands.json
# OpenWRT SDKs (downloaded; see packaging/openwrt)
.openwrt-sdk/
wasm/*.wasm*
wasm/supervisor/*/supervisor.tar
# Supervisor app.wasm are build outputs: wsh/selftest compiled from wapps/,
# sheriff built from the wapps/sheriff submodule (see wasm/supervisor/Makefile).
wasm/supervisor/wsh/app.wasm
wasm/supervisor/selftest/app.wasm
wasm/supervisor/sheriff/app.wasm
wasm/supervisor/wifi-connect/app.wasm
wapps/*/*.wasm
wapps/*/*.wasm.h
wapps/*/*.o
# Registry root (REGISTRY_ROOT): packaged .wapp images staged at runtime/test.
/registry/
*.wat

# NuttX sim scratch (staged hostfs root; test/nuttx-sim.sh). The nuttx +
# nuttx-apps trees themselves are the third_party/ submodules.
/build-nuttx/
utils/measure_structs
platform/nuttx/app/boot-romfs.h
wasm/registry-seed/

# RP2350 dev signing key (test/rp2350-sign-verify.sh) - generated locally,
# never committed. A real production key would live outside this repo entirely.
/keys/
# OpenWRT .ipk output
/dist/

# container scratch written into the mounted repo
.cache/
.bash_history
