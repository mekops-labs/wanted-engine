# psram-s3 resource envelope.
#
# ESP32-S3 with octal PSRAM. The host-managed WASM heap is off (0): the
# fragmented PSRAM allocator serves the runtime better than a fixed pool.
#
# Values are written out in full rather than minimised against the defaults,
# so a board's envelope is readable here without cross-referencing Kconfig.

CONFIG_WANTED_MAX_WAPPS=20
CONFIG_WANTED_WASM_STACK_SIZE=65536
CONFIG_WANTED_WASM_HEAP_SIZE=0
CONFIG_WANTED_WASM_WORKER_STACK_SIZE=65536
CONFIG_WANTED_WASM_MAX_MEMORY_PAGES=16
CONFIG_WANTED_MAX_PATH_LEN=256
CONFIG_WANTED_MAX_DRIVERS_CNT=6
CONFIG_WANTED_MAX_OPTIONS_SIZE=128
