# big resource envelope.
#
# Linux hosts and cloud. WASM_MAX_MEMORY_PAGES=0 lifts the per-wapp linear
# memory cap, which is only safe behind a real memory manager.
#
# Values are written out in full rather than minimised against the defaults,
# so a board's envelope is readable here without cross-referencing Kconfig.

CONFIG_WANTED_MAX_WAPPS=64
CONFIG_WANTED_WASM_STACK_SIZE=131072
CONFIG_WANTED_WASM_HEAP_SIZE=1048576
CONFIG_WANTED_WASM_WORKER_STACK_SIZE=131072
CONFIG_WANTED_WASM_MAX_MEMORY_PAGES=0
CONFIG_WANTED_MAX_PATH_LEN=4096
CONFIG_WANTED_MAX_DRIVERS_CNT=16
CONFIG_WANTED_MAX_OPTIONS_SIZE=1024
