# XIAO ESP32-S3 (ESP-IDF, octal PSRAM). The host-managed WASM heap is off —
# the fragmented PSRAM allocator serves the runtime better than a fixed pool.
#
# Linear memory is capped at 2 pages (128 KiB) per wapp so a full house fits
# the 8 MB PSRAM: 20 slots x ~289 KiB is ~5.7 MB. The cap is deliberately
# below the arithmetic ceiling (3 pages) because `make sizes` excludes the
# per-image writable module copy — one .wasm per running wapp, out of the
# same PSRAM — and the image cache. A wapp needing more linear memory is
# refused at load, which is the intended loud failure.

CONFIG_WANTED_MAX_WAPPS=20
CONFIG_WANTED_WASM_STACK_SIZE=65536
CONFIG_WANTED_WASM_HEAP_SIZE=0
CONFIG_WANTED_WASM_WORKER_STACK_SIZE=65536
CONFIG_WANTED_WASM_MAX_MEMORY_PAGES=2
CONFIG_WANTED_MAX_PATH_LEN=256
CONFIG_WANTED_MAX_DRIVERS_CNT=6
CONFIG_WANTED_MAX_OPTIONS_SIZE=128

# wsh is what this board's firmware has always embedded; the bring-up config
# grants it the ota driver, a log mount and reachability sockets.
CONFIG_WANTED_SUPERVISOR_WSH=y
CONFIG_WANTED_DEFAULT_CONFIG="configs/bringup-esp32s3.json"
