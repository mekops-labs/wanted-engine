{
    "system": {
        "privileged": true
    },
    "supervisor": {
        "imagePath": "./wasm/supervisor/sheriff/supervisor.tar",
        "params": {
            "console": {
                "in":  {"name": "platform"},
                "out": {"name": "platform"},
                "err": {"name": "platform"}
            },
            "drivers": [
                {"name": "wanted"},
                {"name": "sha256"},
                {"name": "ed25519"},
                {"name": "inflate"}
            ],
            "mounts": [
                {"name": "platform", "path": "/var/lib/sheriff"}
            ],
            "sockets": [
                {"name": "manager", "address": "tcp://localhost:8080"},
                {"name": "registry", "address": "tcp://localhost:5000"}
            ]
        }
    }
}
