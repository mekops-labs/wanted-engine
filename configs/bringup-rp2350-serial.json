{
    "system": {
        "privileged": true
    },
    "supervisor": {
        "params": {
            "console": {
                "in":  {"name": "platform"},
                "out": {"name": "platform"},
                "err": {"name": "platform"}
            },
            "drivers": [
                {"name": "wanted"},
                {"name": "sha256"},
                {"name": "ed25519"},
                {"name": "inflate"}
            ],
            "mounts": [
                {
                    "name": "platform",
                    "path": "/var/lib/sheriff",
                    "options": "src=/mnt/flash/sheriff"
                }
            ],
            "sockets": [
                {"name": "manager", "address": "serial:///dev/ttyACM0"}
            ],
            "envs": [
                "SHERIFF_DEVICE_ID=",
                "SHERIFF_MARSHAL_KEY_1=REPLACE_WITH_64_HEX_CHARS"
            ]
        }
    }
}
