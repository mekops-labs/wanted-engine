# GL-iNet Beryl (GL-MT1300, mipsel) under OpenWrt, installed as an .ipk.
# Router-class: real RAM, no MMU pressure, so the small envelope applies.
# Class 2 host — OpenWrt builds the engine as an external package with no
# shared Kconfig namespace; the host-guard catches what a preprocessor can.

CONFIG_WANTED_MAX_WAPPS=16
CONFIG_WANTED_WASM_STACK_SIZE=65536
CONFIG_WANTED_WASM_HEAP_SIZE=262144
CONFIG_WANTED_WASM_WORKER_STACK_SIZE=65536
CONFIG_WANTED_WASM_MAX_MEMORY_PAGES=16
CONFIG_WANTED_MAX_PATH_LEN=512
CONFIG_WANTED_MAX_DRIVERS_CNT=8
CONFIG_WANTED_MAX_OPTIONS_SIZE=256

CONFIG_WANTED_SUPERVISOR_WSH=y
CONFIG_WANTED_SUPERVISOR_IMAGE_PATH="/usr/share/wanted/supervisor.tar"
