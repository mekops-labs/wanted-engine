{
    "system": {
        "privileged": true
    },
    "supervisor": {
        "imagePath": "/srv/wanted/supervisor.tar",
        "params": {
            "console": {
                "in":  {"name": "platform"},
                "out": {"name": "platform"},
                "err": {"name": "platform"}
            },
            "drivers": [
                {"name": "wanted"},
                {"name": "sha256"},
                {"name": "ed25519"},
                {"name": "inflate"}
            ],
            "mounts": [
                {
                    "name": "platform",
                    "path": "/var/lib/sheriff",
                    "options": "src=/srv/wanted/sheriff"
                }
            ]
        }
    }
}
