# Classic ESP32 (Waveshare ESP32 One) under NuttX.
#
# Worker stacks must live in internal DRAM (reachable while the cache is off for
# flash ops/ISRs), which is scarce once WiFi and the PSRAM-backed engine are
# resident. 24 KiB fits two stacks alongside the WiFi buffers; 32 KiB fits one,
# and the 64 KiB default does not allocate at all. The classic interpreter keeps
# the wasm operand stack separate.
#

CONFIG_WANTED_MAX_WAPPS=3
CONFIG_WANTED_WASM_STACK_SIZE=8192
CONFIG_WANTED_WASM_HEAP_SIZE=8192
CONFIG_WANTED_WASM_WORKER_STACK_SIZE=24576
CONFIG_WANTED_WASM_MAX_MEMORY_PAGES=1
CONFIG_WANTED_MAX_PATH_LEN=256
CONFIG_WANTED_MAX_DRIVERS_CNT=6
CONFIG_WANTED_MAX_OPTIONS_SIZE=128
