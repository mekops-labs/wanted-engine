#!/bin/sh /etc/rc.common
# WANTED engine — procd service.
# shellcheck disable=SC2034  # USE_PROCD/START/STOP are consumed by /etc/rc.common

USE_PROCD=1
START=95
STOP=10

CONFIG=/etc/wanted/config.json
# Persistent overlay storage: registry + any staged supervisor image.
DATADIR=/srv/wanted

start_service() {
	mkdir -p "$DATADIR/registry"

	procd_open_instance
	# Run from DATADIR so ./registry and ./data land on persistent storage.
	procd_set_param command /bin/sh -c "cd '$DATADIR' && exec /usr/bin/wanted-cli '$CONFIG'"
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}
