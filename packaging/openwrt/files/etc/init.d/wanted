#!/bin/sh /etc/rc.common
# WANTED engine — procd service.
# shellcheck disable=SC2034  # USE_PROCD/START/STOP are consumed by /etc/rc.common
# shellcheck disable=SC3043  # `local` is ash, which is what runs this

USE_PROCD=1
START=95
STOP=10

# Packaged config: structure (drivers, console, mounts). Deployment values come
# from UCI and are merged into a tmpfs copy at every start, so a stale render
# cannot outlive a config change or a reboot.
BASE_CONFIG=/etc/wanted/config.json
RUN_CONFIG=/var/run/wanted/config.json
DATADIR=/srv/wanted

. /usr/share/libubox/jshn.sh

render_config() {
	local device_id manager registry pubkey missing

	config_load wanted
	config_get device_id main device_id
	config_get manager   main manager
	config_get registry  main registry
	config_get pubkey    main marshal_pubkey

	[ -n "$device_id" ] || device_id=$(uci -q get system.@system[0].hostname)
	[ -n "$device_id" ] || device_id=$(cat /proc/sys/kernel/hostname)

	missing=
	[ -n "$manager" ] || missing="$missing manager"
	[ -n "$pubkey" ] || missing="$missing marshal_pubkey"
	if [ -n "$missing" ]; then
		logger -t wanted -p daemon.err \
			"not starting — unset in /etc/config/wanted:$missing"
		return 1
	fi

	if [ ! -f "$BASE_CONFIG" ]; then
		logger -t wanted -p daemon.err "not starting — missing $BASE_CONFIG"
		return 1
	fi

	json_init
	if ! json_load "$(cat "$BASE_CONFIG")"; then
		logger -t wanted -p daemon.err "not starting — $BASE_CONFIG is not valid JSON"
		return 1
	fi

	json_select supervisor
	json_select params
	json_add_array sockets
	json_add_object ""
	json_add_string name manager
	json_add_string address "$manager"
	json_close_object
	if [ -n "$registry" ]; then
		json_add_object ""
		json_add_string name registry
		json_add_string address "$registry"
		json_close_object
	fi
	json_close_array
	json_add_array envs
	json_add_string "" "SHERIFF_DEVICE_ID=$device_id"
	json_add_string "" "SHERIFF_MARSHAL_PUBKEY=$pubkey"
	json_close_array
	json_select ..
	json_select ..

	mkdir -p "$(dirname "$RUN_CONFIG")"
	# jshn escapes every '/' as '\/'. Legal JSON and the engine's parser
	# handles it, but it makes the rendered file unreadable when debugging.
	json_dump | sed 's|\\/|/|g' > "$RUN_CONFIG"
	chmod 0600 "$RUN_CONFIG"
}

start_service() {
	render_config || return 0

	# sheriff/ backs the supervisor's /var/lib/sheriff mount (identity, state);
	# the engine does not create a mount's host directory.
	mkdir -p "$DATADIR/registry" "$DATADIR/sheriff"

	procd_open_instance
	# Run from DATADIR so ./registry and ./data land on persistent storage.
	procd_set_param command /bin/sh -c "cd '$DATADIR' && exec /usr/bin/wanted-cli '$RUN_CONFIG'"
	procd_set_param respawn
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

service_triggers() {
	procd_add_reload_trigger "wanted"
}

reload_service() {
	restart
}
